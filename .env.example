# OAuth - Codex (OpenAI)
CODEX_CLIENT_ID=your_codex_client_id
CODEX_CLIENT_SECRET=your_codex_client_secret_here

# Direct API Keys (if not using OAuth)
OPENAI_API_KEY=sk-your-openai-key
NVIDIA_API_KEY=your-nvidia-key
OPENROUTER_API_KEY=your-openrouter-key

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Callback server settings
CALLBACK_SERVER_PORT=1455

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Explicit OAuth callback URL for Vercel / custom domains.
# Use this when the deployed origin must stay stable across environments.
CODEX_OAUTH_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/codex/callback
